# ─── Database (Neon Postgres) ───────────────────────────────────────────────
# Neon pooled connection string. Works with node-postgres (`pg`) on both a
# Hostinger VPS and Vercel unchanged.
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/sccc?sslmode=require

# ─── Admin auth (single shared credential) ──────────────────────────────────
ADMIN_EMAIL=admin@siamesecatclub.com
# bcrypt hash — generate with: pnpm create-admin
ADMIN_PASSWORD_HASH=
# Secret for iron-session cookie encryption. Must be at least 32 characters.
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ─── PromptPay / bank (payment display) ─────────────────────────────────────
# Phone number (0812345678) or 13-digit citizen ID used to generate the QR.
PROMPTPAY_ID=0812345678
BANK_NAME=Kasikornbank
BANK_ACCOUNT_NAME=Siamese Cat Creative Club Co., Ltd.
BANK_ACCOUNT_NUMBER=123-4-56789-0

# ─── File storage (payment-proof photos) ────────────────────────────────────
# Directory on the server disk where uploaded proof photos are written.
UPLOAD_DIR=/var/sccc/uploads

# ─── Public config (exposed to the browser) ─────────────────────────────────
NEXT_PUBLIC_TERMS_URL=https://siamesecatclub.com/terms
NEXT_PUBLIC_PRIVACY_URL=https://siamesecatclub.com/privacy
NEXT_PUBLIC_SHOP_NAME="Siamese Cat Creative Club"
# Legal entity name, shown on the printed receipt under the shop brand line.
NEXT_PUBLIC_COMPANY_NAME="Siamese Cat Cafe Co., Ltd."
